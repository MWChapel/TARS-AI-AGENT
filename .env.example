# LM Studio chat endpoint (OpenAI-compatible)
LM_STUDIO_URL=http://localhost:1234/v1

# LM Studio API key — set this to whatever key you configured in
# LM Studio → Developer → API Key. If you left it at the default,
# use "lm-studio" (any non-empty string works in older versions).
LM_STUDIO_API_KEY=lm-studio

# Model identifier shown in LM Studio (the name it uses, or "local-model")
CHAT_MODEL=local-model

# Local Whisper model — downloaded once to ~/.cache/tars-agent/ on first run.
# Smaller = faster but less accurate. English-only (.en) models are faster.
#   Xenova/whisper-tiny.en   ~77 MB   (default, fastest)
#   Xenova/whisper-base.en   ~145 MB  (better accuracy)
#   Xenova/whisper-small.en  ~465 MB  (best local accuracy)
WHISPER_MODEL=Xenova/whisper-tiny.en

# Set to "false" to disable voice input entirely (type-only mode)
WHISPER_ENABLED=true

# macOS voices: Fred (robotic), Zarvox (alien), Daniel (British), Alex (US male)
TTS_VOICE=Fred

# Set to "false" to mute TARS (text only)
TTS_ENABLED=true

# TARS personality dials (0–100)
TARS_HUMOR=75
TARS_HONESTY=90
