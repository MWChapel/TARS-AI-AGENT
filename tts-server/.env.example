# This is a separate Python process from the main Node app, so it reads its
# own .env file (this one, from this directory) rather than the root .env.
# Copy this to .env and edit as needed: cp .env.example .env

# Port this server listens on -- must match QWEN_TTS_URL in the main app's .env
TARS_TTS_PORT=8008

# Hugging Face model id (MLX build). Pick ONE of:
#   mlx-community/Qwen3-TTS-12Hz-1.7B-Base-8bit         (default -- voice cloning, see TARS_TTS_REF_* below)
#   mlx-community/Qwen3-TTS-12Hz-1.7B-CustomVoice-8bit  (named voices, see TARS_TTS_VOICE below)
# The 8-bit quantized variant generates at ~3x real-time on Apple Silicon --
# the bf16 variant is ~0.7x real-time (slower than playback), which causes
# audible stutter/gaps on longer responses as `sox` outruns generation. Stick
# with 8-bit unless you've verified bf16 keeps up on your hardware.
TARS_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-Base-8bit

# Named voice -- ONLY works with a CustomVoice model above. Leave unset to use
# voice cloning (TARS_TTS_REF_AUDIO/TARS_TTS_REF_TEXT below) instead.
# Choices: serena, vivian, uncle_fu, ryan, aiden, ono_anna, sohee, eric, dylan
#TARS_TTS_VOICE=ryan

# Reference clip to clone the voice from -- ONLY used when TARS_TTS_VOICE is
# unset (Base model). URL (downloaded once, cached in ~/.cache/tars-agent/tts/)
# or local path. TARS_TTS_REF_TEXT must be the exact transcript of the clip.
#TARS_TTS_REF_AUDIO=https://qianwen-res.oss-cn-beijing.aliyuncs.com/Qwen3-TTS-Repo/clone.wav
#TARS_TTS_REF_TEXT=Okay. Yeah. I resent you. I love you. I respect you. But you know what? You blew it! And thanks to you.

TARS_TTS_LANGUAGE=English
TARS_TTS_SAMPLE_RATE=24000
TARS_TTS_STREAMING_INTERVAL=0.32
